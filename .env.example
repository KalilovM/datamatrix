# =============================================================================
# DataMatrix Environment Variables Template (single source)
# =============================================================================
# Local dev:
#   copy to .env.local
# Production VPS:
#   use /etc/datamatrix/.env (created automatically by scripts/vps-setup.sh)
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOSTNAME=127.0.0.1

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/datamatrix_dev?schema=public"
# Production example:
# DATABASE_URL="postgresql://datamatrix_user:REPLACE_WITH_STRONG_DB_PASSWORD@localhost:5432/datamatrix_prod?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/datamatrix_dev?schema=public"

# -----------------------------------------------------------------------------
# NextAuth / Session
# -----------------------------------------------------------------------------
# Generate secrets with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Local:
# NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://dm.alonamoda.com"
NEXTAUTH_URL="http://localhost:3000"

SESSION_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# -----------------------------------------------------------------------------
# App URLs / Domain
# -----------------------------------------------------------------------------
NEXT_API_URL="http://localhost:3000"
APP_DOMAIN="localhost"

# -----------------------------------------------------------------------------
# SSL/Certbot (production)
# -----------------------------------------------------------------------------
SSL_EMAIL="admin@alonamoda.com"

# -----------------------------------------------------------------------------
# Logging / Debug
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
DEBUG_PRISMA=true

# -----------------------------------------------------------------------------
# Public vars (exposed to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="DataMatrix"
NEXT_PUBLIC_API_URL="http://localhost:3000"
